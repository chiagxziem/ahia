{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "sortImports": {
    "internalPattern": ["@/"],
    "sortSideEffects": true,
    "customGroups": [
      {
        "groupName": "repo",
        "elementNamePattern": ["@repo/**"]
      }
    ],
    "groups": [
      ["value-builtin", "type-builtin"],
      ["value-external", "type-external"],
      "repo",
      ["value-internal", "type-internal"],
      [
        "value-parent",
        "type-parent",
        "value-sibling",
        "type-sibling",
        "value-index",
        "type-index"
      ],
      "style",
      "unknown"
    ]
  },
  "sortTailwindcss": {
    "stylesheet": "./apps/web/src/styles/globals.css",
    "functions": ["clsx", "cn", "twMerge"],
    "attributes": ["class", "className"]
  },
  "sortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": [
    "**/generated/**",
    "**/migrations/**",
    "**/*.gen.*",
    "**/worker-configuration.d.ts"
  ]
}
